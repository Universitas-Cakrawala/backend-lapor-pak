generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PELAPOR
  ADMIN
}

enum ReportStatus {
  MENUNGGU
  DIPROSES
  SELESAI
}

model User {
  id            String          @id @default(uuid())
  username      String          @unique
  fullName      String
  email         String          @unique
  phone         String
  passwordHash  String
  role          Role            @default(PELAPOR)
  instansi      String?
  fcmToken      String?         // Firebase Cloud Messaging device token (Temuan #4)
  createdAt     DateTime        @default(now())

  reports       Report[]        @relation("PelaporReports")
  statusChanges StatusHistory[] @relation("AdminChanges")
}

model Report {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation("PelaporReports", fields: [userId], references: [id])
  roadName    String
  description String
  latitude    Float
  longitude   Float
  photoUrls   String[]
  videoUrl    String?
  status      ReportStatus    @default(MENUNGGU)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  history     StatusHistory[]
}

model StatusHistory {
  id          String       @id @default(uuid())
  reportId    String
  report      Report       @relation(fields: [reportId], references: [id])
  status      ReportStatus
  note        String?
  proofPhotoUrl String?      // Bukti penyelesaian laporan (FR-14)
  changedById String?
  changedBy   User?        @relation("AdminChanges", fields: [changedById], references: [id])
  timestamp   DateTime     @default(now())
}
