generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  username      String          @unique
  fullName      String
  email         String          @unique
  phone         String
  passwordHash  String
  role          Role            @default(PELAPOR)
  instansi      String?
  fcmToken      String?
  createdAt     DateTime        @default(now())
  reports       Report[]        @relation("PelaporReports")
  statusChanges StatusHistory[] @relation("AdminChanges")
  notifications Notification[]
}

model Report {
  id          String          @id @default(uuid())
  userId      String
  roadName    String
  description String
  latitude    Float
  longitude   Float
  photoUrls   String[]
  videoUrl    String?
  status      ReportStatus    @default(MENUNGGU)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation("PelaporReports", fields: [userId], references: [id])
  history     StatusHistory[]
}

model StatusHistory {
  id            String       @id @default(uuid())
  reportId      String
  status        ReportStatus
  note          String?
  proofPhotoUrl String?
  changedById   String?
  timestamp     DateTime     @default(now())
  changedBy     User?        @relation("AdminChanges", fields: [changedById], references: [id])
  report        Report       @relation(fields: [reportId], references: [id])
}

enum Role {
  PELAPOR
  ADMIN
}

enum ReportStatus {
  MENUNGGU
  DIPROSES
  SELESAI
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  reportId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
